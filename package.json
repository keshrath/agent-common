{
  "name": "agent-common",
  "version": "1.0.2",
  "description": "Shared foundation for agent-* MCP servers — SQLite, REST, WebSocket, MCP, cleanup, events, dashboard scaffolding",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "better-sqlite3": "12.8.0",
    "ws": "8.20.0"
  },
  "peerDependencies": {
    "better-sqlite3": ">=11",
    "ws": ">=8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "keywords": [
    "mcp",
    "agent",
    "sqlite",
    "websocket",
    "model-context-protocol",
    "ai-agents",
    "shared-foundation"
  ],
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/keshrath/agent-common.git"
  },
  "homepage": "https://github.com/keshrath/agent-common#readme",
  "bugs": {
    "url": "https://github.com/keshrath/agent-common/issues"
  }
}
